# OpenAI (required)
OPENAI_API_KEY=sk-...

# Anthropic — used by Script Generator for higher-quality code generation
ANTHROPIC_API_KEY=sk-ant-...

# LangSmith — optional, for pipeline tracing and debugging
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=foto-owl-pipeline

# Pipeline settings
IMAGES_DIR=./images            # directory containing event photos
MAX_IMAGES=12                  # max images to analyse (cost control)
MAX_RETRIES=3                  # compiler retry limit
OUTPUT_DIR=./out               # rendered video output

# RAG settings
CHROMA_PERSIST_DIR=./chroma_db

# Remotion settings
REMOTION_PROJECT_DIR=./remotion

# Model overrides (optional — defaults shown)
INTENT_PARSER_MODEL=gpt-4o-mini
IMAGE_ANALYSER_MODEL=gpt-4o
STORYBOARD_MODEL=gpt-4o-mini
SCRIPT_GENERATOR_MODEL=claude-sonnet-4-5
COMPILER_FIXER_MODEL=gpt-4o-mini
